# URL da API (sem barra final).
#
# Recomendado em desenvolvimento: deixe VAZIO — usa o proxy Vite (/wellpaid-api → 127.0.0.1:8000)
# e evita erros de CORS entre localhost e 127.0.0.1.
# VITE_API_BASE_URL=
#
# Alternativa: API direta (exige CORS_ORIGINS no backend a incluir a origem do painel,
# ex.: http://localhost:5173,http://127.0.0.1:5173).
# VITE_API_BASE_URL=http://127.0.0.1:8000
#
VITE_API_BASE_URL=
